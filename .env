# ==============================================
# 1. CẤU HÌNH MẠNG BLOCKCHAIN (SEPOLIA)
# ==============================================
ETHEREUM_RPC=https://ethereum-sepolia-rpc.publicnode.com
# Hardhat dùng biến này
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ==============================================
# 2. VÍ VÀ BẢO MẬT
# ==============================================
# Private Key ví deploy (Đã lấy từ thông tin bạn cung cấp)
PRIVATE_KEY=

# Key Admin cho Backend Python (Dùng chung với ví deploy để có quyền Owner)
ADMIN_PRIVATE_KEY=

# API Key Etherscan (Để verify code, có thể để trống nếu không cần verify)
ETHERSCAN_API_KEY=

# ==============================================
# 3. ĐỊA CHỈ SMART CONTRACT (QUAN TRỌNG)
# ==============================================
# Các dòng này đang để trống.
# Sau khi chạy lệnh: npx hardhat run scripts/deploy.js --network sepolia
# Bạn hãy copy kết quả từ Terminal điền vào đây.
USDT_ADDRESS=
SOLAR_TOKEN_ADDRESS=
INVESTMENT_CONTRACT=
ORACLE_CONTRACT=

# ==============================================
# 4. CẤU HÌNH BACKEND (FLASK)
# ==============================================
CHAIN_ID=11155111
FLASK_ENV=development
SECRET_KEY=sunchain_secret
# Tự động duyệt KYC để test nhanh (true/false)
KYC_AUTO_APPROVE=true
DATABASE_URL=sqlite:///sunchain.db